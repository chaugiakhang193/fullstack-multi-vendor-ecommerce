# Application Environment (development, production)
NODE_ENV=development

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_uuid_or_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_uuid_or_string

# Token expiration times (e.g. 15m for 15 minutes, 30d for 30 days)
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=30d

# Mail configuration (Gmail App Password or SMTP)
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_smtp_app_password

# Port and URLs
PORT=8080
FRONTEND_URL=http://localhost:3000

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Geocoding configuration
NOMINATIM_EMAIL=your_contact_email@example.com
NOMINATIM_USER_AGENT=YourAppName/1.0 (your_contact_email@example.com)
NOMINATIM_API_URL=https://nominatim.openstreetmap.org/search

# Fallback Geocoding provider (e.g. goong, locationiq, opencage)
FALLBACK_GEOCODING_PROVIDER=goong
FALLBACK_GEOCODING_API_URL=https://rsapi.goong.io/Geocode
FALLBACK_GEOCODING_API_KEY=your_fallback_api_key_here

# LocationIQ Autocomplete (provider CHÍNH cho gợi ý địa chỉ — proxy qua /geocoding/autocomplete)
# Lấy key tại https://locationiq.com (gói free ~5.000 req/ngày)
LOCATIONIQ_API_KEY=your_locationiq_api_key_here
LOCATIONIQ_AUTOCOMPLETE_URL=https://api.locationiq.com/v1/autocomplete



# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:<BACKEND_PORT>/api/v1/auth/google/callback
