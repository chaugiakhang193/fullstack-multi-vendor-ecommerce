# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_uuid_or_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_uuid_or_string

# Token expiration times (e.g. 15m for 15 minutes, 30d for 30 days)
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=30d

# Mail configuration (Gmail App Password or SMTP)
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_smtp_app_password

# Port and URLs
PORT=8080
FRONTEND_URL=http://localhost:3000

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
